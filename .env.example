# Prisma MySQL format:
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Use 127.0.0.1 instead of localhost to avoid socket/DNS surprises on some machines.
DATABASE_URL="mysql://root:password@127.0.0.1:3306/invoice_app"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: seed creates this system owner when email/password are provided.
SUPER_ADMIN_EMAIL="min.khorspace@gmail.com"
SUPER_ADMIN_PASSWORD="min0919Invoice"
SUPER_ADMIN_NAME="System Owner"
