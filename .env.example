# Copy this file to .env for local development.
# In production, configure these values in Hostinger's environment variable panel.
# Never commit .env or real passwords/secrets.

# Prisma MySQL format:
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local Docker example:
# mysql://root:password@127.0.0.1:3306/invoice_app
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Use a long random value in production, for example:
# openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Public base URL used for WhatsApp/PDF links.
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Optional: used only when manually running yarn seed to create the system owner.
SUPER_ADMIN_EMAIL="owner@example.com"
SUPER_ADMIN_PASSWORD="replace-with-a-strong-password"
SUPER_ADMIN_NAME="System Owner"

# Development-only demo records. Keep false in production.
SEED_DEMO_DATA="true"
