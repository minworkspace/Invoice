{
  "name": "invoice-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build && node scripts/prepare-standalone-deploy.mjs",
    "start": "node .next/standalone/server.js",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "db:health": "tsx scripts/db-health.ts",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.0.0",
    "pdfkit": "^0.15.1",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
